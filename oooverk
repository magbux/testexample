local function getNearestPlayerTo(targetP)
	local closest, dist = nil, 999999
	if targetP and targetP.Character and targetP.Character:FindFirstChild("HumanoidRootPart") then
		local tPos = targetP.Character.HumanoidRootPart.Position
		for _, p in pairs(Players:GetPlayers()) do
			if p ~= LocalPlayer and p ~= targetP and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
				local d = (p.Character.HumanoidRootPart.Position - tPos).Magnitude
				if d < dist then
					dist = d
					closest = p
				end
			end
		end
	end
	return closest
end
local function findPlayerPartial(text)
	for _, p in pairs(Players:GetPlayers()) do
		if string.find(string.lower(p.Name), string.lower(text)) or string.find(string.lower(p.DisplayName), string.lower(text)) then
			return p
		end
	end
	return nil
end
