local function stopEnergize()
	if energizeTrack then
		energizeTrack:Stop()
		energizeTrack = nil
	end
	if energizeLoop then
		task.cancel(energizeLoop)
		energizeLoop = nil
	end
end
local function playEnergize(id, speed, weight, loopCount, isLoopingLogic)
	stopEnergize()
	if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
		local anim = Instance.new("Animation")
		anim.AnimationId = "rbxassetid://" .. id
		energizeTrack = LocalPlayer.Character.Humanoid:LoadAnimation(anim)
		if isLoopingLogic then
			energizeLoop = task.spawn(function()
				while true do
					if energizeTrack and not energizeTrack.IsPlaying then
						energizeTrack:Play(0.1, 1, speed)
					end
					task.wait()
				end
			end)
		end
		energizeTrack:Play(0.1, 1, speed)
	end
end
local function executeCommand(cmd)
	if not isControlled then return end
	Notify("Command", cmd)
	local char = LocalPlayer.Character
	local hum = char and char:FindFirstChild("Humanoid")
	local hrp = char and char:FindFirstChild("HumanoidRootPart")
	if cmd == "jump" then
		if hum then hum:ChangeState(Enum.HumanoidStateType.Jumping) end
	elseif cmd == "bring" then
		isBusy = true
		if hrp and followTargetPlayer and followTargetPlayer.Character then
			hrp.CFrame = followTargetPlayer.Character.HumanoidRootPart.CFrame * CFrame.new(followXOffset,0,2.5)
		end
		task.wait(0.5)
		isBusy = false
	elseif cmd == "move_left" then
		followXOffset = followXOffset - 2
	elseif cmd == "move_right" then
		followXOffset = followXOffset + 2
	elseif cmd == "spin" then
		spinEnabled = not spinEnabled
	elseif cmd == "kill" then
		isBusy = true
		char:BreakJoints()
		task.wait(1)
		isBusy = false
	elseif cmd == "void" then
		isBusy = true
		hrp.CFrame = CFrame.new(0, -500, 0)
		task.wait(1)
		isBusy = false
	elseif cmd == "jumpscare" then
		triggerJumpscare()
	elseif cmd == "fling_self" then
		isBusy = true
		hiddenfling = true
		task.wait(2)
		hiddenfling = false
		isBusy = false
	elseif cmd == "fling_nearest" then
		isBusy = true
		local nearest = getNearestPlayerTo(followTargetPlayer)
		if nearest and nearest.Character and nearest.Character:FindFirstChild("HumanoidRootPart") then
			local oldPower = flingPower
			flingPower = 50000
			flingTargetPlayer = nearest
			hiddenfling = true
			Notify("Flinging", "Target: " .. nearest.Name)
			local t = 0
			while t < 30 and flingTargetPlayer do
				RunService.Heartbeat:Wait()
				t = t + 1
			end
			hiddenfling, flingTargetPlayer, flingPower = false, nil, oldPower
			if hrp and followTargetPlayer and followTargetPlayer.Character then
				hrp.CFrame = followTargetPlayer.Character.HumanoidRootPart.CFrame * CFrame.new(followXOffset,0,2.5)
			end
		end
		isBusy = false
	elseif cmd == "stand" then
		isBusy, orbitEnabled, dogMode, standEnabled, followXOffset = false, false, false, true, 0
		stopEnergize()
	elseif cmd == "togglestand" then
		standEnabled = not standEnabled
		if not standEnabled and standPlatform then
			standPlatform.CFrame = CFrame.new(0, -500, 0)
		end
		Notify("Stand Toggle", "Following: " .. tostring(standEnabled))
	elseif cmd == "free" then
		isControlled, controllerPlayer, followTargetPlayer, orbitEnabled, spasmEnabled = false, nil, nil, false, false
		shakeEnabled, dogMode, hiddenfling, rainbowEnabled, drunkEnabled, antiSitEnabled = false, false, false, false, false, false
		fakeLagEnabled, confusionEnabled, ghostEnabled, standEnabled, flingTargetPlayer, followXOffset = false, false, false, true, nil, 0
		stopEnergize()
		if signalConnection then
			signalConnection:Disconnect()
			signalConnection = nil
		end
		if standPlatform then
			standPlatform:Destroy()
			standPlatform = nil
		end
		updateStatus("STATUS: FREE", Color3.fromRGB(100, 255, 100))
		Notify("Freed", "You are no longer controlled.")
